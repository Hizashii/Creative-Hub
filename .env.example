# Copy this file to ".env" in the same folder as package.json, then edit values.
# Do not use markdown code fences in .env — only lines like KEY=value below.

MONGO_URI=mongodb://127.0.0.1:27017/creativehub
JWT_ACCESS_SECRET=replace-with-a-long-random-string-at-least-32-chars
PORT=5000

# Optional: Atlas (mongodb+srv needs DNS SRV; VPN/firewalls/Pi-hole sometimes block it → use "standard" URI below)
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/creativehub?retryWrites=true&w=majority
#
# If connect fails with querySrv / _mongodb._tcp: in Atlas → Connect → Drivers pick "standard connection string"
# (mongodb://host1:27017,host2:27017/...) and set that as MONGO_URI.

# Optional dev only — never in production
# SKIP_AUTH=true
# DEV_USER_ID=507f1f77bcf86cd799439011
# DEV_USER_ROLE=admin
